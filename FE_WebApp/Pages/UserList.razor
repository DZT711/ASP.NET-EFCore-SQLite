@page "/users"
@inject HttpClient Http

<PageTitle>User List</PageTitle>

<h2 class="mb-4">Users from SQLite Database</h2>

@if (users == null)
{
    <div class="d-flex align-items-center">
        <strong>Đang tải dữ liệu...</strong>
        <div class="spinner-border ms-auto" role="status" aria-hidden="true"></div>
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Account Balance</th>
                <th>Created Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in users)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>@user.Role</td>
                    <td>@user.AccountBalance.ToString("C")</td>
                    <td>@user.CreatedDate.ToString("dd/MM/yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<UserDto> users = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Call backend API on port 5000
            users = await Http.GetFromJsonAsync<List<UserDto>>("users") ?? new();
            Console.WriteLine($"Loaded {users.Count} users from database");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error calling API: {ex.Message}");
            users = new List<UserDto>();
        }
    }

    public class UserDto
    {
        public int Id { get; set; }
        public string? Name { get; set; }
        public string? Email { get; set; }
        public string? Role { get; set; }
        public decimal AccountBalance { get; set; }
        public DateOnly CreatedDate { get; set; }
    }
}